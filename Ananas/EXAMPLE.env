# ───────── ANANAS Messenger 환경변수 예시 ─────────
# 이 파일을 복사해 .env 로 만들고 값을 채우세요.  (.env 는 절대 커밋 금지)

# 서버
PORT=4000
NODE_ENV=production
# 운영 도메인 (배포 후 발급된 주소). 예) https://ananas.up.railway.app
CORS_ORIGIN=https://your-app-domain.com

# 인원/메시지 한도
ROOM_MAX_USERS=100
MAX_MESSAGES_PER_ROOM=500
SOCKET_RATE_LIMIT=60
SERVER_MAX_CONNECTIONS=1000

# ───────── 보안 DB (필수) ─────────
# 암호화 SQLite 저장 경로. 무료 호스팅에서는 "영구 볼륨" 경로로 지정해야
# 재배포 시 대화가 사라지지 않습니다. (예: Railway 볼륨 /data)
DB_PATH=/data/ananas.db

# DB 디스크 암호화 키 (절대 외부 노출 금지!).
# 아래 명령으로 강력한 키를 생성해 붙여넣으세요:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=여기에_생성한_64자리_키를_붙여넣으세요

# ───────── AI 어시스턴트 (선택) ─────────
ANTHROPIC_API_KEY=
