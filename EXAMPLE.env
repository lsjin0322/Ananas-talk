# ───────── ANANAS Messenger 환경변수 예시 ─────────
# 이 파일을 복사해 .env 로 만들고 값을 채우세요.  (.env 는 절대 커밋 금지)

# 서버
PORT=4000
NODE_ENV=production
# 운영 도메인 (배포 후 발급된 주소). 예) https://ananas.up.railway.app
CORS_ORIGIN=https://your-app-domain.com

# 인원/메시지 한도
ROOM_MAX_USERS=100
MAX_MESSAGES_PER_ROOM=500
SOCKET_RATE_LIMIT=60
SERVER_MAX_CONNECTIONS=1000
# 빈 방 자동삭제 유예(ms). 모두 나가고 이 시간 뒤에도 비면 삭제(거의 즉시)
EMPTY_ROOM_TTL_MS=3000

# ───────── 관리자 (관리자/사용자 분리) ─────────
# 관리자 토큰. 강력한 값으로 설정하세요. 푸터 "관리자" 또는 ?admin=토큰 으로 로그인.
# 관리자만 AI 키 설정·모델 정보 등을 볼 수 있습니다.
ADMIN_KEY=강력한_관리자_토큰_입력

# ───────── 보안 DB (필수) ─────────
# 암호화 SQLite 저장 경로. 무료 호스팅에서는 "영구 볼륨" 경로로 지정해야
# 재배포 시 대화가 사라지지 않습니다. (예: Railway 볼륨 /data)
DB_PATH=/data/ananas.db

# DB 디스크 암호화 키 (절대 외부 노출 금지!).
# 아래 명령으로 강력한 키를 생성해 붙여넣으세요:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=여기에_생성한_64자리_키를_붙여넣으세요

# ───────── AI 어시스턴트 — Google Gemini (무료, 선택) ─────────
# https://aistudio.google.com/apikey 에서 무료 키 발급 (AIza... 형식)
# 비워두면 관리자 화면에서 직접 입력해도 됩니다.
GEMINI_API_KEY=
# 사용할 모델 (기본 gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash-lite
